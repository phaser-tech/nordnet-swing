# =============================================
# Local development configuration
# Copy to .env and fill in. .env is gitignored.
# =============================================

# --- Database ---
POSTGRES_USER=nordnet_swing
POSTGRES_PASSWORD=local_dev_only_change_me
POSTGRES_DB=nordnet_swing
POSTGRES_PORT=5432
DATABASE_URL=postgresql://nordnet_swing:local_dev_only_change_me@localhost:5432/nordnet_swing

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=console  # 'console' for dev, 'json' for production

# --- Nordnet API (fill in when phase 1 starts) ---
# NORDNET_USERNAME=
# NORDNET_API_KEY=
# NORDNET_PRIVATE_KEY_PATH=~/.nordnet/private.pem
# NORDNET_API_BASE_URL=https://www.nordnet.se/api/2

# --- Trading limits (hard caps, must be configured) ---
MAX_CAPITAL_SEK=100000
MAX_TRADES_PER_DAY=5
MAX_POSITION_SIZE_SEK=20000
